# Copy to `.env` in the project root (same folder as docker-compose.yml).
# Docker Compose reads this file for variable substitution (e.g. ${JWT_SECRET}).

# Required length >= 32 for the Node backend (see backend/src/index.ts).
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# PostgreSQL (db service). Change for production.
POSTGRES_PASSWORD=replace-with-a-strong-db-password
